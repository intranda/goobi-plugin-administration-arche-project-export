<config_plugin>

    <api enableValidation="true" enableIngest="false">
        <!-- url and credentials -->
        <!-- leave url blank, if only file export is needed -->
        <archeApiUrl>http://127.0.0.1/api/</archeApiUrl>
        <archeUserName>admin</archeUserName>
        <archePassword>admin</archePassword>
    </api>
    <project>
        <!-- project property name to store the arche url -->
        <archeUrlPropertyName>ArcheLocation</archeUrlPropertyName>
        <!-- default image for each project -->
        <placeholderImage>/opt/digiverso/goobi/xslt/logo.png</placeholderImage>

        <!-- list of properties to display -->
        <!-- each property has  a name, 
                                a default value (optional), 
                                a type (text, textarea, list, boolean, date, vocabulary), select values, if needed,
                                a ttlType (literal or resource)
            if list was selected: subelement select contains label and actual value
                                -->


        <property name="title"
            repeatable="true" languageField="true"
            default=""
            type="text"
            ttlField="hasTitle" ttlType="literal"
        />


        <property name="contact" default="" type="list" ttlField="hasContact" ttlType="resource"
            repeatable="true" languageField="false">
            <select label="Austrian Centre for Digital Humanities and Cultural Heritage" value="https://arche.acdh.oeaw.ac.at/api/48505" />
            <select label="Austrian Academy of Sciences" value="https://arche.acdh.oeaw.ac.at/api/21003" />
        </property>


        <property name="license" default="" type="vocabularyreference" ttlField="hasLicense" ttlType="resource" repeatable="false" languageField="false">
            <vocabulary
                name="Licenses"
                label="Label"
                value="URI"
                url="https://vocabs.acdh.oeaw.ac.at/rest/v1/arche_licenses/data?format=application/rdf%2Bxml"
                xslt="/home/robert/git/goobi-plugin-administration-arche-project-export/install/rdf2csv.xsl" />
        </property>


        <property name="contributor" default="https://arche.acdh.oeaw.ac.at/api/21828" type="list" ttlField="hasContributor" ttlType="resource" repeatable="true" languageField="false">
            <select label="Max Mustermann" value="https://arche.acdh.oeaw.ac.at/api/21828" />
        </property>

        <property name="digitisingAgent" default="https://arche.acdh.oeaw.ac.at/api/21828" type="list" ttlField="hasDigitisingAgent" ttlType="resource">
            <select label="Max Mustermann" value="https://arche.acdh.oeaw.ac.at/api/21828" />
        </property>

        <property name="metadataCreator" default="https://arche.acdh.oeaw.ac.at/api/21828" type="list" ttlField="hasMetadataCreator" ttlType="resource" repeatable="true" languageField="false">
            <select label="Max Mustermann" value="https://arche.acdh.oeaw.ac.at/api/21828" />
        </property>

        <!-- values from https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/ -->
        <property name="relatedDiscipline" default="" type="list" ttlField="hasRelatedDiscipline" ttlType="resource">
            <select label="" value="" />
            <select label="History, Archaeology" value="https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/504031" />
            <select label="Medical chemistry" value="https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/504026" />
            <select label="Criminal law" value="https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/504022" />
            <select label="Numismatics" value="https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/504016" />
            <select label="Financial law" value="https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/504010" />
            <select label="Nanoelectronics" value="https://vocabs.acdh.oeaw.ac.at/oefosdisciplines/504003" />
        </property>


        <property name="description"
            repeatable="true" languageField="true"
            default="tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet."
            type="textarea"
            ttlField="hasDescription" ttlType="literal"
        />

        <property name="subject"
            repeatable="true" languageField="true"
            default="Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod tempor invidunt ut labore et dolore magna aliquyam erat, sed diam voluptua. At vero eos et accusam et justo duo dolores et ea rebum. 
                    Stet clita kasd gubergren, no sea takimata sanctus est Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet, consetetur sadipscing elitr, sed diam nonumy eirmod"
            type="textarea"
            ttlField="hasSubject"
            ttlType="literal"
        />


        <property name="owner" default="" type="list" ttlField="hasOwner" ttlType="resource" repeatable="true" languageField="false">
            <select label="Austrian Centre for Digital Humanities and Cultural Heritage" value="https://arche.acdh.oeaw.ac.at/api/48505" />
            <select label="Austrian Academy of Sciences" value="https://arche.acdh.oeaw.ac.at/api/21003" />
        </property>

        <property name="licensor" default="" type="list" ttlField="hasLicensor" ttlType="resource" repeatable="true" languageField="false">
            <select label="Austrian Centre for Digital Humanities and Cultural Heritage" value="https://arche.acdh.oeaw.ac.at/api/48505" />
            <select label="Austrian Academy of Sciences" value="https://arche.acdh.oeaw.ac.at/api/21003" />
        </property>


        <property name="depositor" default="https://arche.acdh.oeaw.ac.at/api/21828" type="list" ttlField="hasDepositor" ttlType="resource" repeatable="true" languageField="false">
            <select label="Max Mustermann" value="https://arche.acdh.oeaw.ac.at/api/21828" />
        </property>

        <property name="curator" default="https://arche.acdh.oeaw.ac.at/api/21828" type="list" ttlField="hasCurator" ttlType="resource" repeatable="true" languageField="false">
            <select label="Max Mustermann" value="https://arche.acdh.oeaw.ac.at/api/21828" />
        </property>

        <!-- TODO

hasUrl	0-n		anyURI	30	Presentation (data set) (tab "Content settings")	"We would actually need only the first part of the URL, https://viewer.acdh.oeaw.ac.at/viewer 
Also, it would be nice to have the URL of the official site for the collection too (https://www.oeaw.ac.at/forschung/bibliothek-archiv-sammlungen/sammlung-woldan) which is now in the ARCHE metadata.
        Should we create a separate property for this?"
-->
        <property name="url" repeatable="true" languageField="false" default="https://viewer.acdh.oeaw.ac.at/viewer" type="text" ttlField="hasUrl" ttlType="uri" />

        <property name="rightsHolder" default="https://arche.acdh.oeaw.ac.at/api/21003" type="list" ttlField="hasRightsHolder" ttlType="resource" repeatable="true" languageField="false">
            <select label="Austrian Academy of Sciences" value="https://arche.acdh.oeaw.ac.at/api/21003" />
        </property>

        <!--use
        values from https://vocabs.acdh.oeaw.ac.at/archelicenses
        <property name="license" default="https://vocabs.acdh.oeaw.ac.at/archelicenses/publicdomain-1-0" type="list" ttlField="hasLicense" ttlType="resource">
            <select label="Public Domain Mark 1.0 (PDM)" value="https://vocabs.acdh.oeaw.ac.at/archelicenses/publicdomain-1-0" />
