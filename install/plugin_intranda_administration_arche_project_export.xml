        <property name="Editor" default="https://arche.acdh.oeaw.ac.at/api/21003" type="list" ttlField="hasEditor" ttlType="resource" repeatable="true" languageField="false">
            <select label="Max Mustermann" value="https://arche.acdh.oeaw.ac.at/api/21828" />
        </property>


    </project>

    <!-- language codes -->
    <languages>
        <language label="Deutsch" value="de" />
        <language label="Englisch" value="en" />
        <language label="Undefinied" value="und" />
    </languages>

    <!-- export folder, leave it blank if no file is needed -->
    <exportFolder>/tmp</exportFolder>
</config_plugin>